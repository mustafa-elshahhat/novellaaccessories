ASPNETCORE_ENVIRONMENT=Development
ConnectionStrings__DefaultConnection=

# Startup database lifecycle. Both default to false so Production never migrates/seeds implicitly.
# Enable explicitly per environment (e.g. true in local Development). Controlled independently.
Database__AutoMigrate=false
Database__AutoSeed=false

# JWT: SigningKey is REQUIRED in Production (min 32 chars; placeholder/dev values are rejected).
Jwt__Issuer=
Jwt__Audience=
Jwt__SigningKey=
Jwt__ExpiryDays=7
Jwt__AdminExpiryMinutes=60

# Admin bootstrap password — required only when Database__AutoSeed=true and an admin must be created.
Seed__AdminPassword=
# Development catalog gate. When true (e.g. local dev), the seeder also creates sample products and,
# if Cloudinary is configured, uploads development hero/category/product images. Keep false/unset in
# Production so it never gets development products/images implicitly.
Seed__EnableDevelopmentCatalog=false
Auth__CookieDomain=
Cloudinary__CloudName=
Cloudinary__ApiKey=
Cloudinary__ApiSecret=
WhatsApp__BaseUrl=
WhatsApp__InternalApiKey=
Payment__ActiveProvider=
Payment__WebhookSecret=
Cors__StorefrontOrigin=
Cors__AdminOrigin=
ForwardedHeaders__ForwardLimit=2
ForwardedHeaders__TrustAllProxies=false
