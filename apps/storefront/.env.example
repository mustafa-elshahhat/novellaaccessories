# Server-only base URL of the Novella API (apps/api). NEVER prefix with NEXT_PUBLIC_.
# The browser never calls apps/api directly; same-origin BFF route handlers forward here.
API_BASE_URL=

# Public site URL (used for canonical URLs, hreflang, sitemap, OG, CSRF origin check).
NEXT_PUBLIC_SITE_URL=https://novellaaccessories.store

# Localization.
NEXT_PUBLIC_DEFAULT_LOCALE=ar
NEXT_PUBLIC_SUPPORTED_LOCALES=ar,en

# First-party analytics toggle.
NEXT_PUBLIC_ANALYTICS_ENABLED=true

# Public WhatsApp support link (a wa.me URL). NOT the internal WhatsApp sidecar.
NEXT_PUBLIC_WHATSAPP_SUPPORT_URL=
